digraph constrained_decoding_flow {
	rankdir=LR
	graph [dpi=150 fontname="DejaVu Sans" fontsize=12 size="12,10"]
	graph [label="Ciclo de Decodificación Restringida" labelfontsize=14 labelloc=top]
	step1 [label="LLM produce
Logits" fillcolor="#1A3A5C" fontcolor=white shape=box style=filled]
	step2 [label="FSM determina
