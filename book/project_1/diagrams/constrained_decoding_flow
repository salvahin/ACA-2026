	step5 [label="Softmax &
Sample token" fillcolor="#2E86AB" fontcolor=white shape=box style=filled]
	step6 [label="Actualiza estado
FSM con token" fillcolor="#C73E1D" fontcolor=white shape=box style=filled]
	decision [label="¿Token END
o max length?" fillcolor="#1A3A5C" fontcolor=white shape=diamond style=filled]
