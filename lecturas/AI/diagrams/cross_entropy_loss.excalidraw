    {"type":"text","id":"lossboxt","x":665,"y":108,"width":290,"height":60,"text":"CROSS-ENTROPY LOSS\nL = -log(P(\"Madrid\")) = -log(0.659) ≈ 0.42","originalText":"CROSS-ENTROPY LOSS\nL = -log(P(\"Madrid\")) = -log(0.659) ≈ 0.42","fontSize":16,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":50003,"version":1,"versionNonce":50004,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"lossbox","lineHeight":1.3},

