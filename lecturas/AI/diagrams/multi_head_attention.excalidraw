    {"type":"text","id":"formulat","x":20,"y":340,"width":190,"height":222,"text":"Fórmula completa:\n\nMHA(Q,K,V) =\n  Concat(\n    head₁,...,headₕ\n  ) @ W_O\n\ndonde:\n  headᵢ = Att(\n    X@W_Qᵢ,\n    X@W_Kᵢ,\n    X@W_Vᵢ\n  )","originalText":"Fórmula completa:\n\nMHA(Q,K,V) =\n  Concat(\n    head₁,...,headₕ\n  ) @ W_O\n\ndonde:\n  headᵢ = Att(\n    X@W_Qᵢ,\n    X@W_Kᵢ,\n    X@W_Vᵢ\n  )","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"middle","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":99103,"version":1,"versionNonce":99104,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"formula","lineHeight":1.35},
