    {"type":"text","id":"insightt","x":790,"y":340,"width":170,"height":222,"text":"¿Por qué\nfunciona?\n\nCada cabeza\naprende un\ntipo diferente\nde relación.\n\nGPT-3: 96\ncabezas con\nd_k=128\n(12288 / 96)","originalText":"¿Por qué\nfunciona?\n\nCada cabeza\naprende un\ntipo diferente\nde relación.\n\nGPT-3: 96\ncabezas con\nd_k=128\n(12288 / 96)","fontSize":12,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":99203,"version":1,"versionNonce":99204,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":"insight","lineHeight":1.35}
