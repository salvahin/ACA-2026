digraph transformer {
	bgcolor=white fontname=Arial rankdir=TB
	node [fontname=Arial fontsize=11 shape=box style="rounded,filled"]
	input [label="Input
Embeddings" fillcolor="#E8F5E9"]
	pos [label="Positional
Encoding" fillcolor="#E8F5E9"]
	subgraph cluster_encoder {
		bgcolor="#E3F2FD" label="Encoder Block (×N)" style=rounded
		mha1 [label="Multi-Head
Self-Attention" fillcolor="#BBDEFB"]
		add1 [label="Add & Norm" fillcolor="#90CAF9"]
		ffn1 [label="Feed Forward
Network" fillcolor="#BBDEFB"]
		add2 [label="Add & Norm" fillcolor="#90CAF9"]
	}
	subgraph cluster_decoder {
		bgcolor="#FFF3E0" label="Decoder Block (×N)" style=rounded
		mha2 [label="Masked
Self-Attention" fillcolor="#FFE0B2"]
		add3 [label="Add & Norm" fillcolor="#FFCC80"]
		mha3 [label="Cross-Attention" fillcolor="#FFE0B2"]
		add4 [label="Add & Norm" fillcolor="#FFCC80"]
		ffn2 [label="Feed Forward
Network" fillcolor="#FFE0B2"]
		add5 [label="Add & Norm" fillcolor="#FFCC80"]
	}
	linear [label=Linear fillcolor="#F3E5F5"]
	softmax [label=Softmax fillcolor="#F3E5F5"]
	output [label="Output
Probabilities" fillcolor="#E1BEE7"]
	input -> pos
	pos -> mha1
	mha1 -> add1
	add1 -> ffn1
	ffn1 -> add2
	add2 -> mha2 [label="encoder output" style=dashed]
	mha2 -> add3
	add3 -> mha3
	mha3 -> add4
	add4 -> ffn2
	ffn2 -> add5
	add5 -> linear
	linear -> softmax
	softmax -> output
}
