    {"type":"text","id":"title","x":10,"y":6,"width":880,"height":22,"text":"FIRST y FOLLOW Sets: Cálculo y Uso en Tablas de Parsing","originalText":"FIRST y FOLLOW Sets: Cálculo y Uso en Tablas de Parsing","fontSize":16,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1,"version":1,"versionNonce":2,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

