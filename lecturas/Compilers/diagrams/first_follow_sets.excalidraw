    {"type":"text","id":"table_h","x":10,"y":240,"width":880,"height":14,"text":"Tabla de Parsing LL(1) — celda [No-terminal, Token] = regla a aplicar","originalText":"Tabla de Parsing LL(1) — celda [No-terminal, Token] = regla a aplicar","fontSize":12,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":43,"version":1,"versionNonce":44,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"table_c","x":18,"y":258,"width":864,"height":20,"text":"  Token →    \"(\"          ID          NUM           \"+\"        \"×\"          \")\"         EOF\nfactor:   F→(expr)    F→ID       F→NUM       ERROR       ERROR     ERROR     ERROR      ← filas usando FIRST y FOLLOW","originalText":"  Token →    \"(\"          ID          NUM           \"+\"        \"×\"          \")\"         EOF\nfactor:   F→(expr)    F→ID       F→NUM       ERROR       ERROR     ERROR     ERROR      ← filas usando FIRST y FOLLOW","fontSize":10,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":45,"version":1,"versionNonce":46,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4}
