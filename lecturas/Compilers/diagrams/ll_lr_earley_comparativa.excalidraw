    {"type":"text","id":"bottom_t","x":18,"y":254,"width":864,"height":18,"text":"Poder: LL(1) ⊂ LR(1) ⊂ CFG-completo (Earley)     Velocidad práctica: LR(1) ≈ LL(1) >> Earley     Flexibilidad: Earley >> LR(1) > LL(1)","originalText":"Poder: LL(1) ⊂ LR(1) ⊂ CFG-completo (Earley)     Velocidad práctica: LR(1) ≈ LL(1) >> Earley     Flexibilidad: Earley >> LR(1) > LL(1)","fontSize":12,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#2d3e56","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":43,"version":1,"versionNonce":44,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
