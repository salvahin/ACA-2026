    {"type":"text","id":"xgrammar_t","x":18,"y":254,"width":864,"height":18,"text":"XGrammar usa un enfoque híbrido: especificación EBNF (como generator) + Earley parser compilado (como combinator adaptativo). Ideal para DSLs con gramáticas cambiantes en runtime.","originalText":"XGrammar usa un enfoque híbrido: especificación EBNF (como generator) + Earley parser compilado (como combinator adaptativo). Ideal para DSLs con gramáticas cambiantes en runtime.","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"middle","strokeColor":"#2d3e56","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":103,"version":1,"versionNonce":104,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
