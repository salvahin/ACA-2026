    {"type":"text","id":"lv","x":60,"y":80,"width":400,"height":18,"text":"Vocab:  ID=0   '+'=1   '*'=2   ')'=3   '('=4   ';'=5","originalText":"Vocab:  ID=0   '+'=1   '*'=2   ')'=3   '('=4   ';'=5","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1301,"version":1,"versionNonce":1302,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"ls1","x":60,"y":104,"width":400,"height":18,"text":"q0: válidos {ID, '('}       →  mask[q0] = 0b010001 = 0x11","originalText":"q0: válidos {ID, '('}       →  mask[q0] = 0b010001 = 0x11","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#78350f","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1401,"version":1,"versionNonce":1402,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"ls2","x":60,"y":126,"width":400,"height":18,"text":"q1: válidos {'+', '*', ')'}  →  mask[q1] = 0b001110 = 0x0E","originalText":"q1: válidos {'+', '*', ')'}  →  mask[q1] = 0b001110 = 0x0E","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#78350f","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1501,"version":1,"versionNonce":1502,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
