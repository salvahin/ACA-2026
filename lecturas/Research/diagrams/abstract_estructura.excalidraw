    {"type":"text","id":"a4c","x":547,"y":66,"width":150,"height":84,"text":"Métricas clave +\nestadísticos esenciales\n\n\"Las restricciones\nmejoraron validez de\n75.1% a 85.2%\n(p=.006, d=0.71),\ncon overhead de\n12% en latencia...\"","originalText":"Métricas clave +\nestadísticos esenciales\n\n\"Las restricciones\nmejoraron validez de\n75.1% a 85.2%\n(p=.006, d=0.71),\ncon overhead de\n12% en latencia...\"","fontSize":10,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":821,"version":1,"versionNonce":822,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

