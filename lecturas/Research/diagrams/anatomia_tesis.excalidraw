    {"type":"text","id":"ref_c","x":458,"y":214,"width":424,"height":44,"text":"Zotero: gratis, open-source, mejor integración con Google Scholar  |  Mendeley: Elsevier, bueno para PDFs\nWorkflow: leer paper → guardar en Zotero → etiquetar (GrammarKernels, GPU, Stats) → anotar contribución principal","originalText":"Zotero: gratis, open-source, mejor integración con Google Scholar  |  Mendeley: Elsevier, bueno para PDFs\nWorkflow: leer paper → guardar en Zotero → etiquetar (GrammarKernels, GPU, Stats) → anotar contribución principal","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1321,"version":1,"versionNonce":1322,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"text","id":"footnote","x":10,"y":276,"width":880,"height":18,"text":"Regla de oro: cada capítulo responde una pregunta distinta — el hilo conductor son las RQs que recorren toda la tesis de principio a fin.","originalText":"Regla de oro: cada capítulo responde una pregunta distinta — el hilo conductor son las RQs que recorren toda la tesis de principio a fin.","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1401,"version":1,"versionNonce":1402,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
