    {"type":"text","id":"hedge_h","x":10,"y":208,"width":490,"height":18,"text":"HEDGING — Expresar incertidumbre apropiadamente","originalText":"HEDGING — Expresar incertidumbre apropiadamente","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":411,"version":1,"versionNonce":412,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"hedge_c","x":18,"y":230,"width":474,"height":92,"text":"Sugiere: \"Los resultados sugieren que las restricciones mejoran...\"\nPosible: \"Una posible explicación es que el modelo...\"\nTendencia: \"Los datos muestran una tendencia hacia...\"\nPodría: \"Este hallazgo podría indicar que...\"\n\n✗ Demasiado débil: \"Quizás tal vez posiblemente...\"\n✗ Demasiado fuerte: \"Demostramos que las restricciones SIEMPRE mejoran...\"\n✓ Balance: \"Los resultados sugieren una mejora consistente (d=0.71, IC 95% [0.3, 1.0]) que merece investigación futura.\"","originalText":"Sugiere: \"Los resultados sugieren que las restricciones mejoran...\"\nPosible: \"Una posible explicación es que el modelo...\"\nTendencia: \"Los datos muestran una tendencia hacia...\"\nPodría: \"Este hallazgo podría indicar que...\"\n\n✗ Demasiado débil: \"Quizás tal vez posiblemente...\"\n✗ Demasiado fuerte: \"Demostramos que las restricciones SIEMPRE mejoran...\"\n✓ Balance: \"Los resultados sugieren una mejora consistente (d=0.71, IC 95% [0.3, 1.0]) que merece investigación futura.\"","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#92400e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":421,"version":1,"versionNonce":422,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

