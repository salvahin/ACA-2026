    {"type":"text","id":"va_h","x":10,"y":46,"width":420,"height":18,"text":"VOZ ACTIVA — Prefiere para metodología","originalText":"VOZ ACTIVA — Prefiere para metodología","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#064e3b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":211,"version":1,"versionNonce":212,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"va_c","x":18,"y":68,"width":404,"height":112,"text":"✓ \"Generamos 100 kernels usando GPT-3.5-turbo.\"\n✓ \"Evaluamos la tasa de compilación con nvcc.\"\n✓ \"Aplicamos la prueba de Mann-Whitney U.\"\n\nCuándo usar:\n→ Metodología (qué HICISTE tú)\n→ Contribuciones (qué PROPONES)\n→ Pasos concretos con agente claro\n\nVentaja: más directo, mayor impacto","originalText":"✓ \"Generamos 100 kernels usando GPT-3.5-turbo.\"\n✓ \"Evaluamos la tasa de compilación con nvcc.\"\n✓ \"Aplicamos la prueba de Mann-Whitney U.\"\n\nCuándo usar:\n→ Metodología (qué HICISTE tú)\n→ Contribuciones (qué PROPONES)\n→ Pasos concretos con agente claro\n\nVentaja: más directo, mayor impacto","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":221,"version":1,"versionNonce":222,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

