    {"type":"text","id":"vp_h","x":450,"y":46,"width":440,"height":18,"text":"VOZ PASIVA — Usa para resultados y hechos","originalText":"VOZ PASIVA — Usa para resultados y hechos","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":311,"version":1,"versionNonce":312,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"vp_c","x":458,"y":68,"width":424,"height":112,"text":"✓ \"Se observó una diferencia significativa (p=.006).\"\n✓ \"Los kernels fueron clasificados en tres categorías.\"\n✓ \"Los datos fueron analizados con SciPy 1.11.\"\n\nCuándo usar:\n→ Resultados (los datos 'hablan' solos)\n→ Procedimientos estándar sin novedad\n→ Cuando el agente no importa (o no quieres\n   mencionarte en 3a persona)\n\nVentaja: más objetivo, reduce ego","originalText":"✓ \"Se observó una diferencia significativa (p=.006).\"\n✓ \"Los kernels fueron clasificados en tres categorías.\"\n✓ \"Los datos fueron analizados con SciPy 1.11.\"\n\nCuándo usar:\n→ Resultados (los datos 'hablan' solos)\n→ Procedimientos estándar sin novedad\n→ Cuando el agente no importa (o no quieres\n   mencionarte en 3a persona)\n\nVentaja: más objetivo, reduce ego","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":321,"version":1,"versionNonce":322,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

