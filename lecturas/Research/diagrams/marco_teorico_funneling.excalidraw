    {"type":"text","id":"diff_h","x":10,"y":272,"width":420,"height":16,"text":"Revisión Bibliográfica ≠ Marco Teórico","originalText":"Revisión Bibliográfica ≠ Marco Teórico","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":911,"version":1,"versionNonce":912,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"diff_c","x":18,"y":292,"width":404,"height":54,"text":"Revisión bibliográfica: lista de papers relevantes + qué dice cada uno\n→ Pone en mapa el estado del conocimiento\n\nMarco teórico: SINTETIZA conceptos para fundamentar TU trabajo\n→ Explica por qué tus RQs tienen sentido dado ese fondo","originalText":"Revisión bibliográfica: lista de papers relevantes + qué dice cada uno\n→ Pone en mapa el estado del conocimiento\n\nMarco teórico: SINTETIZA conceptos para fundamentar TU trabajo\n→ Explica por qué tus RQs tienen sentido dado ese fondo","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":921,"version":1,"versionNonce":922,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

