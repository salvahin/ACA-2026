    {"type":"text","id":"def_h","x":450,"y":272,"width":440,"height":16,"text":"Definición de Conceptos Críticos","originalText":"Definición de Conceptos Críticos","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1011,"version":1,"versionNonce":1012,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"def_c","x":458,"y":292,"width":424,"height":54,"text":"Estructura: 1) término, 2) definición operacional, 3) diferencias con términos adyacentes\nEj: \"Kernel GPU válido: código CUDA que compila sin errores de sintaxis y pasa validación de warps.\"\nDiferente de: 'kernel correcto' (puede compilar pero dar resultados incorrectos)","originalText":"Estructura: 1) término, 2) definición operacional, 3) diferencias con términos adyacentes\nEj: \"Kernel GPU válido: código CUDA que compila sin errores de sintaxis y pasa validación de warps.\"\nDiferente de: 'kernel correcto' (puede compilar pero dar resultados incorrectos)","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1021,"version":1,"versionNonce":1022,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

    {"type":"text","id":"footnote","x":10,"y":364,"width":880,"height":18,"text":"El marco teórico exitoso posiciona tu trabajo en el embudo: demuestra que entiendes el campo amplio, conoces el estado del arte, e identificas el gap específico que tú llenas.","originalText":"El marco teórico exitoso posiciona tu trabajo en el embudo: demuestra que entiendes el campo amplio, conoces el estado del arte, e identificas el gap específico que tú llenas.","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1101,"version":1,"versionNonce":1102,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
