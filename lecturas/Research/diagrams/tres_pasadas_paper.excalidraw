    {"type":"text","id":"p2h","x":295,"y":46,"width":265,"height":18,"text":"PASADA 2 — Contribución principal (15-20 min)","originalText":"PASADA 2 — Contribución principal (15-20 min)","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":411,"version":1,"versionNonce":412,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"p2c","x":303,"y":68,"width":249,"height":156,"text":"Lee completamente excepto\nproofs y detalles técnicos.\n\nPreguntas guía:\n• ¿Qué problema resuelve?\n• ¿Cómo lo resuelven?\n• ¿Qué resultados reportan?\n• ¿Qué limitaciones tienen?\n\nAnota mientras lees:\n→ 1 frase contribución\n→ Diferencia con trabajos previos\n→ ¿Cómo citar en tu tesis?","originalText":"Lee completamente excepto\nproofs y detalles técnicos.\n\nPreguntas guía:\n• ¿Qué problema resuelve?\n• ¿Cómo lo resuelven?\n• ¿Qué resultados reportan?\n• ¿Qué limitaciones tienen?\n\nAnota mientras lees:\n→ 1 frase contribución\n→ Diferencia con trabajos previos\n→ ¿Cómo citar en tu tesis?","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":421,"version":1,"versionNonce":422,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

