    {"type":"text","id":"synth_h","x":10,"y":260,"width":880,"height":16,"text":"RESUMEN vs. SÍNTESIS — La diferencia crucial","originalText":"RESUMEN vs. SÍNTESIS — La diferencia crucial","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":711,"version":1,"versionNonce":712,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"synth_c","x":18,"y":278,"width":864,"height":26,"text":"Resumir (evitar): \"Parr et al. propusieron ANTLR que genera parsers a partir de EBNF.\" — Solo repite lo que dice el paper.\nSintetizar (hacer): \"XGrammar extiende el enfoque de Parr añadiendo optimizaciones GPU (O(1) token masking) que ANTLR no provee, habilitando parsing en tiempo real para vocabularios de 50k+ tokens.\"","originalText":"Resumir (evitar): \"Parr et al. propusieron ANTLR que genera parsers a partir de EBNF.\" — Solo repite lo que dice el paper.\nSintetizar (hacer): \"XGrammar extiende el enfoque de Parr añadiendo optimizaciones GPU (O(1) token masking) que ANTLR no provee, habilitando parsing en tiempo real para vocabularios de 50k+ tokens.\"","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":721,"version":1,"versionNonce":722,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

    {"type":"text","id":"footnote","x":10,"y":322,"width":880,"height":18,"text":"Objetivo: Pasada 1 para el 100% de papers candidatos. Pasada 2 para el 30-40% relevantes. Pasada 3 solo para el 5-10% fundamentales.","originalText":"Objetivo: Pasada 1 para el 100% de papers candidatos. Pasada 2 para el 30-40% relevantes. Pasada 3 solo para el 5-10% fundamentales.","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":731,"version":1,"versionNonce":732,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
