    {"type":"text","id":"example_h","x":10,"y":290,"width":880,"height":18,"text":"Ejemplo en Tu Proyecto: Baseline vs Restricciones Gramaticales","originalText":"Ejemplo en Tu Proyecto: Baseline vs Restricciones Gramaticales","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":811,"version":1,"versionNonce":812,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"example_v","x":20,"y":310,"width":860,"height":44,"text":"Baseline: n₁=30, x̄₁=5.2s, s₁=0.8s  |  Restricciones: n₂=30, x̄₂=4.8s, s₂=0.9s\nσ_pooled = √((29×0.64 + 29×0.81)/58) = 0.85   →   d = (5.2−4.8)/0.85 = 0.47  →  Efecto MEDIANO (publicable, mejora práctica ~8%)","originalText":"Baseline: n₁=30, x̄₁=5.2s, s₁=0.8s  |  Restricciones: n₂=30, x̄₂=4.8s, s₂=0.9s\nσ_pooled = √((29×0.64 + 29×0.81)/58) = 0.85   →   d = (5.2−4.8)/0.85 = 0.47  →  Efecto MEDIANO (publicable, mejora práctica ~8%)","fontSize":12,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":821,"version":1,"versionNonce":822,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

