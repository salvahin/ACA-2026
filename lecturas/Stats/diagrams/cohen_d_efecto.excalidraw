    {"type":"text","id":"interp_t","x":370,"y":44,"width":520,"height":18,"text":"Interpretación de d  (reglas de Cohen)","originalText":"Interpretación de d  (reglas de Cohen)","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":311,"version":1,"versionNonce":312,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"interp_v","x":380,"y":62,"width":500,"height":44,"text":"d = 0.2 → PEQUEÑO   |   d = 0.5 → MEDIANO   |   d = 0.8 → GRANDE   |   d > 1.2 → MUY GRANDE\nSiempre reporta AMBOS: p-valor (¿existe diferencia?) + d (¿qué tan importante?)","originalText":"d = 0.2 → PEQUEÑO   |   d = 0.5 → MEDIANO   |   d = 0.8 → GRANDE   |   d > 1.2 → MUY GRANDE\nSiempre reporta AMBOS: p-valor (¿existe diferencia?) + d (¿qué tan importante?)","fontSize":12,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":321,"version":1,"versionNonce":322,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

