    {"type":"text","id":"formula_t","x":10,"y":44,"width":340,"height":18,"text":"Fórmula de Cohen's d","originalText":"Fórmula de Cohen's d","fontSize":13,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":211,"version":1,"versionNonce":212,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"formula_v","x":20,"y":64,"width":320,"height":44,"text":"d = (μ₁ − μ₂) / σ_pooled\nσ_pooled = √[((n₁−1)s₁² + (n₂−1)s₂²) / (n₁+n₂−2)]","originalText":"d = (μ₁ − μ₂) / σ_pooled\nσ_pooled = √[((n₁−1)s₁² + (n₂−1)s₂²) / (n₁+n₂−2)]","fontSize":12,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":221,"version":1,"versionNonce":222,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},

