    {"type":"text","id":"title","x":20,"y":6,"width":880,"height":26,"text":"Distribuciones de Probabilidad: Comparativa Práctica","originalText":"Distribuciones de Probabilidad: Comparativa Práctica","fontSize":18,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e293b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1001,"version":1,"versionNonce":1002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

