    {"type":"text","id":"example_v","x":18,"y":325,"width":864,"height":28,"text":"\"Los kernels con restricciones gramaticales (M = 85.2%, DE = 12.3%) superaron al baseline (M = 75.1%, DE = 15.6%), t(49) = 2.84, p = .006, d = 0.71, IC 95% [3.0%, 16.9%].\n Resultado robusto a variación de semilla (5 seeds; rango: 83.1%–87.4%). El efecto mediano indica mejora práctica relevante en producción.\"","originalText":"\"Los kernels con restricciones gramaticales (M = 85.2%, DE = 12.3%) superaron al baseline (M = 75.1%, DE = 15.6%), t(49) = 2.84, p = .006, d = 0.71, IC 95% [3.0%, 16.9%].\n Resultado robusto a variación de semilla (5 seeds; rango: 83.1%–87.4%). El efecto mediano indica mejora práctica relevante en producción.\"","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1121,"version":1,"versionNonce":1122,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

