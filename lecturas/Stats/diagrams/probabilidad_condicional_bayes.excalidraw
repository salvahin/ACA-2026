    {"type":"text","id":"rh","x":470,"y":46,"width":410,"height":22,"text":"TEOREMA DE BAYES — Invertir condicional","originalText":"TEOREMA DE BAYES — Invertir condicional","fontSize":14,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e1b4b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2401,"version":1,"versionNonce":2402,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"form","x":480,"y":76,"width":390,"height":40,"text":"P(A|B)  =  P(B|A) × P(A)  /  P(B)","originalText":"P(A|B)  =  P(B|A) × P(A)  /  P(B)","fontSize":16,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#1e1b4b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2501,"version":1,"versionNonce":2502,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"form2","x":480,"y":120,"width":390,"height":20,"text":"\"¿Dado el resultado B, cuál es la probabilidad de que la causa fuera A?\"","originalText":"\"¿Dado el resultado B, cuál es la probabilidad de que la causa fuera A?\"","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2601,"version":1,"versionNonce":2602,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"ex_h","x":480,"y":148,"width":390,"height":18,"text":"Aplicación: ¿Si compiló, vino de Restricciones?","originalText":"Aplicación: ¿Si compiló, vino de Restricciones?","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1b4b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2701,"version":1,"versionNonce":2702,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"ex1","x":480,"y":170,"width":390,"height":100,"text":"A = Restricciones\nB = Compiló\n\nP(Restricciones | Compiló)\n  = P(Compiló | R) × P(R)  /  P(Compiló)\n  = 0.85 × 0.50  /  0.80\n  = 0.425 / 0.80  =  0.53","originalText":"A = Restricciones\nB = Compiló\n\nP(Restricciones | Compiló)\n  = P(Compiló | R) × P(R)  /  P(Compiló)\n  = 0.85 × 0.50  /  0.80\n  = 0.425 / 0.80  =  0.53","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1b4b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2801,"version":1,"versionNonce":2802,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},
    {"type":"text","id":"interp","x":480,"y":278,"width":390,"height":40,"text":"Interpretación: El 53% de los kernels que compilaron\nprovienen del método de restricciones gramaticales.","originalText":"Interpretación: El 53% de los kernels que compilaron\nprovienen del método de restricciones gramaticales.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2901,"version":1,"versionNonce":2902,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},
    {"type":"text","id":"key_diff","x":480,"y":324,"width":390,"height":18,"text":"★  P(A|B) ≠ P(B|A)  — Bayes te permite invertir la dirección","originalText":"★  P(A|B) ≠ P(B|A)  — Bayes te permite invertir la dirección","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e1b4b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3001,"version":1,"versionNonce":3002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"fnote","x":20,"y":358,"width":860,"height":18,"text":"P(A|B) = P(A∩B) / P(B) — Definición directa.  Regla de Bayes = P(A∩B) = P(B|A)·P(A) sustituida en la definición.","originalText":"P(A|B) = P(A∩B) / P(B) — Definición directa.  Regla de Bayes = P(A∩B) = P(B|A)·P(A) sustituida en la definición.","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3101,"version":1,"versionNonce":3102,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
