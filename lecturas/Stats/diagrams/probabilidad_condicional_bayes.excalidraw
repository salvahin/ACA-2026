    {"type":"text","id":"calc_h","x":30,"y":185,"width":370,"height":18,"text":"Probabilidades marginales:","originalText":"Probabilidades marginales:","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#78350f","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1801,"version":1,"versionNonce":1802,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"calc1","x":30,"y":205,"width":370,"height":80,"text":"P(Compiló)          = 1600/2000 = 0.80\nP(No Compiló)       = 400/2000  = 0.20\nP(Baseline)         = 1000/2000 = 0.50\nP(Restricciones)    = 1000/2000 = 0.50","originalText":"P(Compiló)          = 1600/2000 = 0.80\nP(No Compiló)       = 400/2000  = 0.20\nP(Baseline)         = 1000/2000 = 0.50\nP(Restricciones)    = 1000/2000 = 0.50","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#78350f","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":1901,"version":1,"versionNonce":1902,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.4},
    {"type":"text","id":"calc_c","x":30,"y":292,"width":370,"height":22,"text":"P(Compiló | Restricciones) = 850/1000 = 0.85 ← condicional","originalText":"P(Compiló | Restricciones) = 850/1000 = 0.85 ← condicional","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2001,"version":1,"versionNonce":2002,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"calc_c2","x":30,"y":316,"width":370,"height":22,"text":"P(Compiló | Baseline)       = 750/1000 = 0.75 ← condicional","originalText":"P(Compiló | Baseline)       = 750/1000 = 0.75 ← condicional","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#3730a3","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2101,"version":1,"versionNonce":2102,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

