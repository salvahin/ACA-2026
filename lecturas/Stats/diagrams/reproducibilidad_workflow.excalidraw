    {"type":"text","id":"s4c","x":652,"y":74,"width":220,"height":92,"text":"seed 42: validez = 85.2%\nseed 123: validez = 84.8%\nseed 456: validez = 86.1%\nseed 789: validez = 84.3%\nseed 999: validez = 85.9%\n\nMedia ± SD = 85.3% ± 0.7%\nConc: efecto robusto a semilla","originalText":"seed 42: validez = 85.2%\nseed 123: validez = 84.8%\nseed 456: validez = 86.1%\nseed 789: validez = 84.3%\nseed 999: validez = 85.9%\n\nMedia ± SD = 85.3% ± 0.7%\nConc: efecto robusto a semilla","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2501,"version":1,"versionNonce":2502,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

