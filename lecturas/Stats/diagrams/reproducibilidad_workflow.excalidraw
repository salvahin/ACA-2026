    {"type":"text","id":"badh","x":30,"y":200,"width":370,"height":18,"text":"✗ MAL: Solo una seed, solo un experimento","originalText":"✗ MAL: Solo una seed, solo un experimento","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2701,"version":1,"versionNonce":2702,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"badc","x":30,"y":222,"width":370,"height":54,"text":"\"Obtuvimos 85.2% con nuestro método\"\n→ Puede ser suerte. Una sola corrida no demuestra nada.\n→ Resultado puede no ser reproducible por otros investigadores.\n→ Rechazado en revisión de paper.","originalText":"\"Obtuvimos 85.2% con nuestro método\"\n→ Puede ser suerte. Una sola corrida no demuestra nada.\n→ Resultado puede no ser reproducible por otros investigadores.\n→ Rechazado en revisión de paper.","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#991b1b","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":2801,"version":1,"versionNonce":2802,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

