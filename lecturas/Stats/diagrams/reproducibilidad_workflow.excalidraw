    {"type":"text","id":"goodc","x":500,"y":222,"width":370,"height":54,"text":"\"Obtuvimos 85.3% ± 0.7% (5 seeds, n=100 por seed)\"\n→ Demuestra consistencia. Varianza baja = resultado real.\n→ Cualquier investigador puede reproducir con las mismas seeds.\n→ Aceptado. Resultados creíbles y verificables.","originalText":"\"Obtuvimos 85.3% ± 0.7% (5 seeds, n=100 por seed)\"\n→ Demuestra consistencia. Varianza baja = resultado real.\n→ Cualquier investigador puede reproducir con las mismas seeds.\n→ Aceptado. Resultados creíbles y verificables.","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#065f46","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3101,"version":1,"versionNonce":3102,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.35},

    {"type":"text","id":"fnote","x":20,"y":292,"width":860,"height":18,"text":"Reproducibilidad ≠ mismos números exactos. Reproducibilidad = misma conclusión bajo variabilidad controlada y documentada.","originalText":"Reproducibilidad ≠ mismos números exactos. Reproducibilidad = misma conclusión bajo variabilidad controlada y documentada.","fontSize":11,"fontFamily":3,"textAlign":"center","verticalAlign":"top","strokeColor":"#475569","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":3201,"version":1,"versionNonce":3202,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25}
