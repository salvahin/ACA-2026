# Gramática EBNF Básica para OpenAI Triton (versión inicial)
# Esta gramática define un subconjunto de Python válido para kernels Triton.

root ::= import_stmts (ws function_def)+

import_stmts ::= ("import triton" newline)? "import triton.language as tl" newline

function_def ::= "@triton.jit" newline "def " identifier "(" parameters "):" newline block

identifier ::= [a-zA-Z_] [a-zA-Z0-9_]*
parameters ::= (identifier (ws "," ws identifier)*)?

# El bloque del kernel debe estar indentado con 4 espacios
block ::= (indent statement newline)+

statement ::= assignment | load_call | store_call | arith_expr | "return"

assignment ::= identifier ws "=" ws expression

# Operaciones comunes de memoria en Triton
load_call ::= "tl.load(" ws expression (ws "," ws "mask=" expression)? ws ")"
store_call ::= "tl.store(" ws expression ws "," ws expression (ws "," ws "mask=" expression)? ws ")"

# Expresiones (simplificadas)
expression ::= term (ws operator ws term)*
term ::= identifier | number | triton_builtin
operator ::= "+" | "-" | "*" | "/" | "%" | "==" | "!=" | "<" | ">" | "<=" | ">="

# Utilidades de Triton como tl.arange, tl.program_id
triton_builtin ::= "tl." identifier "(" args ")"
args ::= (expression (ws "," ws expression)*)?

number ::= [0-9]+ ("." [0-9]+)?

ws ::= [ \t]*
newline ::= "\n" | "\r\n"
indent ::= "    "
